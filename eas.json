{
  "cli": {
    "version": ">= 3.1.1"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "env": {
        "API_URL": "https://dev-app.themeparkshark.com/api"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_URL": "https://dev-app.themeparkshark.com/api"
      },
      "ios": {
        "resourceClass": "m1-medium"
      }
    },
    "production": {
      "env": {
        "API_URL": "https://prod-app.themeparkshark.com/api"
      },
      "ios": {
        "resourceClass": "m1-medium"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
